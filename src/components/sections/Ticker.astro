---
const tickerText = `The Top 1% Own 43.8% of Global Wealth ■ South Africa Is the World's Most Unequal Major Economy ■ Cuba Has More Doctors Per Capita Than the USA — Under a Six-Decade US Embargo ■ China Lifted 800 Million People Out of Extreme Poverty ■ India's Richest 1% Own 40% of National Wealth — a Share Still Rising ■ CEO-to-Worker Pay: 290:1 in the US (peaked at 399:1 in 2021) ■ $5 Trillion Gained by Global Billionaires During COVID-19 ■ 700 Million People Remain in Extreme Poverty After Decades of Capitalist Development ■ Illicit Financial Flows Strip $88 Billion Per Year from Africa — More Than Foreign Aid Received ■ Richest 1% Emit More CO₂ Than the Poorest 50% Combined ■ $7 Trillion in Annual Fossil Fuel Subsidies — IMF 2025 ■ 100 Corporations Responsible for 71% of Global Emissions Since 1988 ■ 1 Million Species Face Extinction Under Capitalist Agribusiness ■ Climate Damage Costs the Global South $400 Billion Per Year ■ Brazil's Richest 10% Hold 58% of National Income — Among the World's Highest ■ Canada Spends 40% Less Per Capita on Healthcare Than the USA — for Better Outcomes ■ NAFTA Cost Mexico 1.3 Million Agricultural Jobs in Its First Decade — a Template for 'Free Trade' ■ Germany Has Legal Worker Board Representation — Yet Its Labour Share of GDP Has Still Fallen 7 Points Since 1980 ■ Indonesia's Forests Are Cleared at a Rate of 600,000 Hectares Per Year — Driven by Palm Oil and Mining Capital ■ The Wealthiest 10 Nations Have Emitted 65% of All Historical CO₂ — the Poorest 10 Nations Less Than 1% ■ $32+ Trillion Held Offshore — Beyond Democratic Reach ■ UK Homeownership for 25–34 Year-Olds Fell from Around 59% to 28% in a Generation ■ Developing Countries Paid $443 Billion in Debt Service in 2022 — Dwarfing Aid Received ■ The The Richest 400 US Families Pay an Effective Tax Rate of Around 23% — Half the Rate of Middle-Class Households ■`;

const srText =
	"Key statistics: The Top 1% Own 43.8% of Global Wealth. CEO-to-Worker Pay: 290:1 in the US (peaked at 399:1 in 2021). $5 Trillion Gained by Global Billionaires During COVID-19. 700 Million People Remain in Extreme Poverty. Richest 1% Emit More CO₂ Than the Poorest 50% Combined. $7 Trillion in Annual Fossil Fuel Subsidies. 100 Corporations Responsible for 71% of Global Emissions Since 1988.";
---

<div class="ticker-wrap" role="region" aria-label="Key statistics ticker">
	<p class="sr-only">{srText}</p>
	<div class="ticker" aria-hidden="true">
		<span set:html={tickerText} /><span set:html={tickerText} />
	</div>
	<button
		type="button"
		class="ticker-pause"
		aria-label="Pause ticker"
		aria-pressed="false"
	>
		<svg
			width="10"
			height="14"
			viewBox="0 0 10 14"
			fill="currentColor"
			aria-hidden="true"
		>
			<rect x="0" y="0" width="3.5" height="14" />
			<rect x="6.5" y="0" width="3.5" height="14" />
		</svg>
	</button>
</div>
