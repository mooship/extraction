---
import StatNumber from "../StatNumber.astro";
---

<section id="hero">
	<div class="hero-grid">
		<div class="hero-left">
			<h1 class="reveal">
				The System<br />
				<span>Is Rigged.</span>
			</h1>
			<p class="reveal" style="transition-delay: 0.15s">
				South Africa did not escape apartheid's economy. It inherited it.
				Wealth does not trickle down — it floods upward. Three decades after
				liberation, the top 1% still hold more wealth than the bottom 93%
				combined. This is not an accident. It is the designed outcome of
				a system built to extract value from workers and transfer it to
				capital owners — a system that predates apartheid, survived it,
				and thrives beneath democracy. The data is unambiguous. The
				injustice is structural. The solution must be structural. And it
				must be collective.
			</p>
			<div class="callout">The data is unambiguous</div>
		</div>
		<div class="hero-right">
			<div class="stat-grid">
				<div class="stat-box" role="group" aria-labelledby="stat-label-0">
					<StatNumber target={0.89} />
					<div class="label" id="stat-label-0">
						South Africa's wealth Gini coefficient — joint-highest of any
						major economy on earth<button
							type="button"
							class="cite-ref"
							aria-label="View source: UBS Global Wealth Report 2021"
							aria-controls="cite-popover" aria-expanded="false"
							data-source="UBS Global Wealth Report (formerly Credit Suisse), 2021"
							data-url="https://www.ubs.com/global/en/family-office-uhnw/reports/global-wealth-report-2021.html"
						>*</button>
					</div>
				</div>
				<div class="stat-box" role="group" aria-labelledby="stat-label-1">
					<StatNumber target={55} suffix="%" />
					<div class="label" id="stat-label-1">
						Of all wealth in South Africa is owned by the top 1% — more
						than the bottom 93% combined<button
							type="button"
							class="cite-ref"
							aria-label="View source: World Inequality Database 2021"
							aria-controls="cite-popover" aria-expanded="false"
							data-source="Chatterjee, Czajka &amp; Gethin, Estimating the Distribution of Household Wealth in South Africa, WID.world, 2021"
							data-url="https://wid.world/country/southafrica/"
						>*</button>
					</div>
				</div>
				<div class="stat-box" role="group" aria-labelledby="stat-label-2">
					<StatNumber target={32.9} suffix="%" />
					<div class="label" id="stat-label-2">
						Unemployment — 41.9% under the expanded definition including
						discouraged workers<button
							type="button"
							class="cite-ref"
							aria-label="View source: Stats SA QLFS Q1 2024"
							aria-controls="cite-popover" aria-expanded="false"
							data-source="Statistics South Africa, Quarterly Labour Force Survey Q1 2024"
							data-url="https://www.statssa.gov.za/?page_id=1854&PPN=P0211"
						>*</button>
					</div>
				</div>
				<div class="stat-box" role="group" aria-labelledby="stat-label-3">
					<StatNumber target={62} suffix="%" />
					<div class="label" id="stat-label-3">
						Of South African children live below the poverty line<button
							type="button"
							class="cite-ref"
							aria-label="View source: Stats SA General Household Survey 2023"
							aria-controls="cite-popover" aria-expanded="false"
							data-source="Statistics South Africa, General Household Survey, 2023"
							data-url="https://www.statssa.gov.za/?page_id=1854&PPN=P0318"
						>*</button>
					</div>
				</div>
				<div class="stat-box stat-box-full" role="group" aria-labelledby="stat-label-4">
					<StatNumber target={1} prefix="Top " suffix="%" />
					<div class="label" id="stat-label-4">
						Globally, emit more CO₂ than the poorest 50% of humanity
						combined — the same class that owns half the world's wealth.
						South Africa's own top emitters, Eskom and Sasol, receive
						billions in state support while the poor bear the costs<button
							type="button"
							class="cite-ref"
							aria-label="View source: Oxfam 2025"
							aria-controls="cite-popover" aria-expanded="false"
							data-source="Oxfam, Carbon Inequality Kills, 2025"
							data-url="https://www.oxfam.org/en/research/carbon-inequality-kills"
						>*</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
