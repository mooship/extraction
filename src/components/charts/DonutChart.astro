---
import { pie } from "d3-shape";
import type { DonutSegment } from "../../data/charts";
import { donutData } from "../../data/charts";

const cx = 200;
const cy = 155;
const r = 100;
const circumference = 2 * Math.PI * r;
const labelRadius = 165;

const pieLayout = pie<DonutSegment>()
	.value((d) => d.percent)
	.sort(null);

const arcs = pieLayout(donutData);

const segments = arcs.map((arc, i) => {
	const segLen =
		((arc.endAngle - arc.startAngle) / (2 * Math.PI)) * circumference;
	const dashArray = `${segLen} ${circumference - segLen}`;
	const dashOffset = -(arc.startAngle / (2 * Math.PI)) * circumference;
	return { ...arc.data, dashArray, dashOffset, i };
});

const labels = arcs.map((arc) => {
	const midAngle = (arc.startAngle + arc.endAngle) / 2 - Math.PI / 2;
	const lx = cx + labelRadius * Math.cos(midAngle);
	const ly = cy + labelRadius * Math.sin(midAngle);
	const anchor = lx > cx ? "start" : "end";
	return { ...arc.data, lx: Math.round(lx), ly: Math.round(ly), anchor };
});
---

<svg
	id="tax-donut-svg"
	role="img"
	aria-labelledby="donut-svg-title"
	viewBox="-30 -10 460 340"
	xmlns="http://www.w3.org/2000/svg"
>
	<title id="donut-svg-title">Where Corporate Profits Are Shifted</title>
	<desc>
		Donut chart showing corporate profit shifting destinations: UK Dependencies
		23%, Netherlands 22%, Bermuda/Cayman 18%, Luxembourg 15%, Ireland 12%,
		Other 4%.
	</desc>
	{segments.map((seg) => (
		<circle
			class="donut-segment"
			data-index={seg.i}
			data-dasharray={seg.dashArray}
			cx={cx}
			cy={cy}
			r={r}
			fill="none"
			stroke={seg.color}
			stroke-width="60"
			stroke-dasharray={seg.dashArray}
			stroke-dashoffset={seg.dashOffset}
			transform={`rotate(-90 ${cx} ${cy})`}
		/>
	))}
	{labels.map((label) => (
		<text
			x={label.lx}
			y={label.ly}
			fill="#888"
			font-size="7"
			text-anchor={label.anchor}
		>
			{label.label} ({label.percent}%)
		</text>
	))}
</svg>
