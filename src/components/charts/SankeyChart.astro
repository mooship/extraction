---
import { linkHorizontal } from "d3-shape";
import { sankeyFlows } from "../../data/charts";

const sourceX = 80;
const targetX = 520;

const linkGen = linkHorizontal<(typeof sankeyFlows)[number], [number, number]>()
	.source((d) =>
		d.direction === "left" ? [sourceX, d.sourceY] : [targetX, d.sourceY],
	)
	.target((d) =>
		d.direction === "left" ? [targetX, d.targetY] : [sourceX, d.targetY],
	);

const flows = sankeyFlows.map((flow) => ({
	...flow,
	path: linkGen(flow) ?? "",
	labelY: (flow.direction === "left" ? flow.sourceY : flow.targetY) + 4,
}));

const leftFlows = flows.filter((f) => f.direction === "left");
const rightFlows = flows.filter((f) => f.direction === "right");
---

<svg
	id="sankey-svg"
	role="img"
	aria-labelledby="sankey-svg-title"
	viewBox="0 0 600 260"
	xmlns="http://www.w3.org/2000/svg"
>
	<title id="sankey-svg-title">The Real Flow of Wealth: South to North</title>
	<desc>
		Sankey flow diagram showing net wealth flows from the Global South to the
		Global North: Unequal Exchange $10.8T, Debt Service $443B, Illicit Flows
		$89B flowing northward, versus only $200B in Aid flowing southward.
	</desc>
	<text x="40" y="20" fill="var(--semantic-red)" font-size="10" font-weight="bold" text-anchor="middle">GLOBAL</text>
	<text x="40" y="32" fill="var(--semantic-red)" font-size="10" font-weight="bold" text-anchor="middle">SOUTH</text>
	<text x="560" y="20" fill="var(--text-muted)" font-size="10" font-weight="bold" text-anchor="middle">GLOBAL</text>
	<text x="560" y="32" fill="var(--text-muted)" font-size="10" font-weight="bold" text-anchor="middle">NORTH</text>
	{flows.map((flow) => (
		<path
			id={`sankey-${flow.label.toLowerCase().replace(/\s+/g, "-")}`}
			class="sankey-path"
			d={flow.path}
			fill="none"
			stroke={flow.color}
			stroke-width={flow.strokeWidth}
			stroke-linecap="round"
			opacity="0.8"
		/>
	))}
	<polygon points="85,55 95,50 95,60" fill="var(--accent)" opacity="0.6" />
	<polygon points="515,220 505,215 505,225" fill="var(--semantic-green)" opacity="0.6" />
	{leftFlows.map((flow) => (
		<text
			x="85"
			y={flow.labelY}
			fill="var(--fg)"
			font-size="8"
			paint-order="stroke"
			stroke="var(--bg)"
			stroke-width="3"
			stroke-linejoin="round"
		>
			{flow.label}: {flow.displayValue}
		</text>
	))}
	{rightFlows.map((flow) => (
		<text
			x="75"
			y={flow.labelY}
			fill="var(--semantic-green)"
			font-size="8"
			paint-order="stroke"
			stroke="var(--bg)"
			stroke-width="3"
			stroke-linejoin="round"
		>
			{flow.label}: {flow.displayValue}
		</text>
	))}
</svg>
