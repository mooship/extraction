---
import { scaleBand, scaleLinear } from "d3-scale";
import { giniDesktopData } from "../../data/charts";

const yTop = 10;
const yBase = 170;

const xScale = scaleBand()
	.domain(giniDesktopData.map((d) => d.label))
	.range([20, 440])
	.padding(0.35);

const yScale = scaleLinear().domain([0.6, 1.0]).range([yBase, yTop]);

const bandwidth = xScale.bandwidth();

const bars = giniDesktopData.map((item, i) => {
	const x = xScale(item.label) ?? 0;
	const barY = Math.round(yScale(item.value));
	const barH = Math.round(yBase - barY);
	const labelX = x + bandwidth / 2;
	return { ...item, x, width: bandwidth, fullY: barY, fullH: barH, labelX, i };
});

const gridValues = [1.0, 0.9, 0.8, 0.7, 0.6];
---

<svg
	id="gini-svg"
	role="img"
	aria-labelledby="gini-svg-title"
	viewBox="0 0 460 200"
	xmlns="http://www.w3.org/2000/svg"
>
	<title id="gini-svg-title">Wealth Gini Coefficient by Country</title>
	<desc>
		Bar chart comparing wealth Gini coefficients: Germany 0.67, France 0.70,
		Sweden 0.74, Brazil 0.78, UK 0.81, USA 0.85, South Africa 0.91. Higher
		values indicate greater inequality.
	</desc>
	{gridValues.map((v) => (
		<line x1="18" y1={yScale(v)} x2="450" y2={yScale(v)} stroke={v === 0.6 ? "#333" : "#1a1a1a"} stroke-width="1" stroke-dasharray={v === 0.6 ? undefined : "4,3"} />
	))}
	{gridValues.map((v) => (
		<text x="14" y={yScale(v) + 3} fill="#888" font-size="8" text-anchor="end">
			{v.toFixed(1)}
		</text>
	))}
	{bars.map((bar) => (
		<>
			<rect
				class="gini-bar"
				data-index={bar.i}
				x={bar.x}
				y={bar.fullY}
				width={bar.width}
				height={bar.fullH}
				style={`fill: ${bar.color}`}
			/>
			<text
				x={bar.labelX}
				y="185"
				style={`fill: ${bar.highlight ? "var(--accent)" : "#888"}`}
				font-size="7"
				font-weight={bar.highlight ? "bold" : "normal"}
				text-anchor="middle"
			>
				{bar.label}
			</text>
		</>
	))}
</svg>
