---
import { scaleLinear } from "d3-scale";
import { area, line } from "d3-shape";
import { historySeriesData } from "../../data/charts";

const xScale = scaleLinear().domain([1914, 2025]).range([50, 795]);
const yScale = scaleLinear().domain([10, 30]).range([225, 45]);

const trendLine = line<(typeof historySeriesData)[number]>()
	.x((d) => xScale(d.year))
	.y((d) => yScale(d.share));

const areaFill = area<(typeof historySeriesData)[number]>()
	.x((d) => xScale(d.year))
	.y0(225)
	.y1((d) => yScale(d.share));

const trendPath = trendLine(historySeriesData) ?? "";
const areaPath = areaFill(historySeriesData) ?? "";

const axisYears = [1914, 1948, 1970, 1994, 2000, 2025];
const filteredYears = historySeriesData.filter((point) =>
	axisYears.includes(point.year),
);

const findYear = (year: number) => {
	const point = historySeriesData.find((p) => p.year === year);
	if (!point) throw new Error(`Missing history data for ${year}`);
	return point;
};
const apartheid = findYear(1948);
const democracy = findYear(1994);
const recent = findYear(2025);
const gearX = xScale(1996);

const eras = [
	{
		x1: xScale(1914),
		x2: xScale(1948),
		fill: "rgba(14,110,112,0.06)",
		label: "COLONIAL ERA",
		labelColor: "rgba(14,110,112,0.4)",
	},
	{
		x1: xScale(1948),
		x2: xScale(1994),
		fill: "rgba(76,175,76,0.05)",
		label: "APARTHEID",
		labelColor: "rgba(76,175,76,0.4)",
	},
	{
		x1: xScale(1994),
		x2: xScale(2025),
		fill: "rgba(14,110,112,0.10)",
		label: "POST-APARTHEID",
		labelColor: "rgba(14,110,112,0.5)",
	},
];

const gridYValues = [30, 25, 20, 15, 10];
---

<svg
	id="history-svg"
	role="img"
	aria-labelledby="history-svg-title"
	viewBox="0 0 820 260"
	xmlns="http://www.w3.org/2000/svg"
>
	<title id="history-svg-title">Top 1% Income Share — South Africa, 1914–2025</title>
	<desc>
		Line chart showing the top 1% income share in South Africa from 1914 to
		2025. The share rose from around 22% in the colonial era to 27% when
		apartheid began in 1948, then fell gradually through the apartheid period,
		and has held at around 19–21% in the post-apartheid era — with the 1996
		GEAR policy preventing any structural redistribution.
	</desc>
	{eras.map((era) => (
		<>
			<rect x={era.x1} y="10" width={era.x2 - era.x1} height="215" fill={era.fill} />
			<text x={era.x1 + 10} y="25" fill={era.labelColor} font-size="8">{era.label}</text>
		</>
	))}
	{gridYValues.map((v) => (
		<line x1="50" y1={yScale(v)} x2="800" y2={yScale(v)} stroke={v === 10 ? "#333" : "#1a1a1a"} stroke-width="1" stroke-dasharray={v === 10 ? undefined : "4,4"} />
	))}
	{gridYValues.map((v) => (
		<text x="44" y={yScale(v) + 3} fill="#888" font-size="8" text-anchor="end">
			{v}%
		</text>
	))}
	{filteredYears.map((point) => (
		<text x={xScale(point.year)} y="243" fill="#888" font-size="8" text-anchor="middle">
			{point.year}
		</text>
	))}
	<path d={areaPath} fill="rgba(14,110,112,0.08)" />
	<path id="hist-line" d={trendPath} fill="none" stroke="var(--accent)" stroke-width="2.5" />
	<line x1={gearX} y1="15" x2={gearX} y2="225" stroke="#555" stroke-width="1" stroke-dasharray="3,3" />
	<text x={gearX + 3} y="60" fill="#888" font-size="7">1996</text>
	<text x={gearX + 3} y="70" fill="#888" font-size="7">GEAR</text>
	<circle cx={xScale(apartheid.year)} cy={yScale(apartheid.share)} r="5" style="fill: var(--accent)" />
	<text x={xScale(apartheid.year) + 6} y={yScale(apartheid.share) - 8} style="fill: var(--accent)" font-size="7">Apartheid begins</text>
	<circle cx={xScale(democracy.year)} cy={yScale(democracy.share)} r="5" fill="#4caf4c" />
	<text x={xScale(democracy.year) + 6} y={yScale(democracy.share) - 7} fill="#4caf4c" font-size="7">Democracy</text>
	<circle cx={xScale(recent.year)} cy={yScale(recent.share)} r="5" style="fill: var(--accent)" />
	<text x={xScale(recent.year) - 38} y={yScale(recent.share) - 8} style="fill: var(--accent)" font-size="7">{recent.share}% (2025)</text>
</svg>
