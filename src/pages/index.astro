---
import BackToTop from "../components/BackToTop.astro";
import CitePopover from "../components/CitePopover.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import Action from "../components/sections/Action.astro";
import Ecology from "../components/sections/Ecology.astro";
import Hero from "../components/sections/Hero.astro";
import Imperialism from "../components/sections/Imperialism.astro";
import Labor from "../components/sections/Labor.astro";
import Manifesto from "../components/sections/Manifesto.astro";
import Public from "../components/sections/Public.astro";
import Tax from "../components/sections/Tax.astro";
import Wealth from "../components/sections/Wealth.astro";
import Base from "../layouts/Base.astro";

const description =
	"South Africa is the most unequal country on earth. A data-driven account of how colonial extraction, apartheid's labour system, and post-apartheid neoliberalism created a crisis where the top 1% hold 55% of all wealth — and what it will take to change it.";
---

<Base
	title="Extraction — South Africa's Anatomy of Inequality"
	description={description}
	canonicalUrl="https://extraction.timothybrits.co.za/"
	ogImage="https://extraction.timothybrits.co.za/android-chrome-512x512.png"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": "Extraction — South Africa's Anatomy of Inequality",
			"description": description,
			"url": "https://extraction.timothybrits.co.za/",
			"inLanguage": "en",
			"isAccessibleForFree": true,
			"about": [
				{ "@type": "Thing", "name": "Wealth inequality" },
				{ "@type": "Place", "name": "South Africa" },
				{ "@type": "Thing", "name": "Apartheid legacy" },
				{ "@type": "Thing", "name": "Eco-socialism" },
				{ "@type": "Thing", "name": "Ecological crisis" },
				{ "@type": "Thing", "name": "Labour rights" },
			],
		})} />
	</Fragment>
	<Nav />
	<main id="main-content">
		<Hero />
		<Wealth />
		<Tax />
		<Labor />
		<Imperialism />
		<Ecology />
		<Public />
		<Manifesto />
		<Action />
	</main>
	<BackToTop />
	<Footer />
	<CitePopover />
</Base>
